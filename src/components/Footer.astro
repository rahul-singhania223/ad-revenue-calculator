---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-hairline)]">
  <div class="mx-auto max-w-7xl px-6 py-16">

    <div class="mb-12 grid gap-10 md:grid-cols-4">

      <!-- Brand -->
      <div class="md:col-span-2">

        <a
          href="/"
          class="mb-4 inline-block text-2xl font-bold tracking-tight text-[var(--color-ink)]"
        >
          Ads
          <span class="text-[var(--color-link)]">
            Revenue
          </span>
        </a>

        <p class="max-w-sm text-sm leading-6 text-[var(--color-body)]">
          The ultimate suite of ad revenue calculators for creators,
          publishers, and developers. Fast, accurate, and completely free to
          use.
        </p>

      </div>


      <!-- Calculators -->
      <div>

        <h3
          class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-ink)]"
        >
          Calculators
        </h3>

        <ul class="space-y-3 text-sm">

          <li>
            <a
              href="/youtube-ad-revenue-calculator"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              YouTube Calculator
            </a>
          </li>

          <li>
            <a
              href="/website-ad-revenue-calculator"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              Website & Google Ads
            </a>
          </li>

          <li>
            <a
              href="/twitch-ad-revenue-calculator"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              Twitch Calculator
            </a>
          </li>

          <li>
            <a
              href="/app-ad-revenue-calculator"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              App & Games Calculator
            </a>
          </li>

        </ul>

      </div>


      <!-- Company -->
      <div>

        <h3
          class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-ink)]"
        >
          Company
        </h3>

        <ul class="space-y-3 text-sm">

          <li>
            <a
              href="/about-us"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              About Us
            </a>
          </li>

          <li>
            <a
              href="/contact-us"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              Contact Us
            </a>
          </li>

          <li>
            <a
              href="/privacy-policy"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              Privacy Policy
            </a>
          </li>

          <li>
            <a
              href="/terms-and-conditions"
              class="text-[var(--color-mute)] transition-colors hover:text-[var(--color-ink)]"
            >
              Terms & Conditions
            </a>
          </li>

        </ul>

      </div>

    </div>


    <div
      class="flex flex-col items-center justify-between gap-4 border-t border-[var(--color-hairline)] pt-8 text-xs text-[var(--color-mute)] md:flex-row"
    >

      <p>
        © {currentYear} Ads Revenue Calculator. All rights reserved.
      </p>

      <p>
        Not affiliated with Google, YouTube, Meta, or Twitch.
      </p>

    </div>

  </div>
</footer>