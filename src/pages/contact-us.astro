---
import BaseLayout from "../layouts/BaseLayout.astro";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Us - Ad Revenue Calculator",
  url: "https://adsrevenuecalculator.com/contact",
  description:
    "Get in touch with the Ads Revenue Calculator team for support, business inquiries, or feature requests.",
};
---

<BaseLayout
  title="Contact Us | Ad Revenue Calculator"
  description="Get in touch with the Ads Revenue Calculator team for support, business inquiries, or feature requests."
  schema={contactSchema}
  canonicalUrl="https://adsrevenuecalculator.com/contact"
>

<div class="mx-auto max-w-6xl grid gap-16 lg:grid-cols-2 mt-12 p-4">

  <!-- Left Column -->
  <div>
    <h1 class="mb-6 text-4xl font-bold tracking-tight text-[var(--color-ink)] md:text-5xl">
      Contact Us
    </h1>

    <p class="mb-10 text-lg leading-8 text-[var(--color-body)]">
      Have a question about how our math works? Want to request a new
      platform calculator? Or maybe you're interested in advertising
      with us? We'd love to hear from you.
    </p>

    <div class="space-y-8">

      <div class="flex items-start gap-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft)]">
          <svg
            class="h-5 w-5 text-[var(--color-primary)]"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            />
          </svg>
        </div>

        <div>
          <h3 class="mb-1 font-semibold text-[var(--color-ink)]">
            Email Us
          </h3>

          <p class="text-sm text-[var(--color-mute)]">
            rahul4software@outlook.com
          </p>
        </div>
      </div>


      <div class="flex items-start gap-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[var(--color-hairline)] bg-[var(--color-canvas-soft)]">
          <svg
            class="h-5 w-5 text-[var(--color-primary)]"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"
            />
          </svg>
        </div>

        <div>
          <h3 class="mb-1 font-semibold text-[var(--color-ink)]">
            Social Media
          </h3>

          <p class="text-sm text-[var(--color-mute)]">
            Follow us on Twitter @RA_one00
          </p>
        </div>
      </div>

    </div>
  </div>


  <!-- Right Column -->
  <div class="rounded-2xl border border-[var(--color-hairline)] p-8">

    <h2 class="mb-6 text-2xl font-bold text-[var(--color-ink)]">
      Send a Message
    </h2>

    <form action="#" method="POST" class="space-y-5">

      <div>
        <label
          for="name"
          class="mb-2 block text-sm font-medium text-[var(--color-ink)]"
        >
          Name
        </label>

        <input
          id="name"
          name="name"
          type="text"
          required
          placeholder="John Doe"
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-[var(--color-canvas-soft)] px-4 py-3 outline-none transition focus:border-[var(--color-hairline-strong)]"
        />
      </div>


      <div>
        <label
          for="email"
          class="mb-2 block text-sm font-medium text-[var(--color-ink)]"
        >
          Email Address
        </label>

        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="john@example.com"
          class="w-full rounded-lg border border-[var(--color-hairline)] bg-[var(--color-canvas-soft)] px-4 py-3 outline-none transition focus:border-[var(--color-hairline-strong)]"
        />
      </div>


      <div>
        <label
          for="message"
          class="mb-2 block text-sm font-medium text-[var(--color-ink)]"
        >
          Message
        </label>

        <textarea
          id="message"
          name="message"
          rows="5"
          required
          placeholder="How can we help you?"
          class="w-full resize-none rounded-lg border border-[var(--color-hairline)] bg-[var(--color-canvas-soft)] px-4 py-3 outline-none transition focus:border-[var(--color-hairline-strong)]"
        />
      </div>


      <button
        type="submit"
        class="w-full rounded-lg bg-[var(--color-primary)] px-4 py-3 font-medium text-[var(--color-on-primary)] transition-opacity hover:opacity-90"
      >
        Send Message
      </button>

    </form>

  </div>

</div>

</BaseLayout>